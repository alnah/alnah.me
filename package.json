{
  "name": "alnah-io",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:static": "node scripts/prepare-static.mjs",
    "predev": "npm run prepare:static",
    "dev": "astro dev",
    "prebuild": "npm run prepare:static",
    "build": "rm -rf dist .astro node_modules/.astro && astro build",
    "preview": "astro preview",
    "test:unit": "node scripts/test-unit.mjs",
    "test:acceptance": "npm run build && node scripts/test-acceptance.mjs",
    "test:integration": "npm run build && node scripts/test-integration.mjs",
    "test:e2e": "npm run build && node scripts/test-e2e.mjs",
    "test:ui": "npm run build && node scripts/test-ui.mjs",
    "verify": "npm run build && node scripts/verify.mjs"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/source-serif-4": "^5.2.9",
    "astro": "^6.0.2",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "playwright": "^1.53.0",
    "typescript": "^5.9.2"
  }
}
