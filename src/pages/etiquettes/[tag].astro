---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";
import { getPostsByTag, getTags } from "../../lib/content";

export async function getStaticPaths() {
  const tags = await getTags();
  return tags.map((tag) => ({
    params: { tag: tag.slug },
    props: { tag }
  }));
}

const { tag } = Astro.props;
const posts = await getPostsByTag(tag.slug);
---

<BaseLayout
  title={`Articles étiquetés ${tag.label}`}
  description={`Articles étiquetés ${tag.label}`}
>
  <section class="archive-shell content-band">
    <div class="prose archive-intro">
      <p class="eyebrow">Archive d'étiquettes</p>
      <h1>#{tag.label}</h1>
      <p>{tag.count} article(s) classé(s) sous cette étiquette.</p>
    </div>
    <PostList posts={posts} />
  </section>
</BaseLayout>
