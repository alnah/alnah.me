---
import { createMarkdownProcessor } from "@astrojs/markdown-remark";
import BaseLayout from "../layouts/BaseLayout.astro";
import GitHubActivity from "../components/GitHubActivity.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";
import { SITE } from "../config/site";
import { getPageContent } from "../lib/content";
import { resolveEntryTitle } from "../lib/document-title.js";
import { buildProfilePageSchema } from "../lib/seo";

const page = await getPageContent("about");

if (!page) {
  throw new Error("Missing about page content");
}

const pageTitle = resolveEntryTitle(page);
const pageDescription = page.data.description ?? SITE.description;
const signupAnchor = "## Support and contact";
const [beforeSignup, afterSignup] = page.body.split(signupAnchor);

if (!beforeSignup || afterSignup === undefined) {
  throw new Error("About page is missing the support-and-contact anchor for newsletter signup placement");
}

const markdownProcessor = await createMarkdownProcessor();
const { code: beforeSignupHtml } = await markdownProcessor.render(beforeSignup);
const { code: afterSignupHtml } = await markdownProcessor.render(`${signupAnchor}${afterSignup}`);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  schemaJson={buildProfilePageSchema({
    canonicalUrl: new URL("/about/", Astro.site).toString(),
    description: pageDescription,
    title: SITE.author.name
  })}
>
  <section class="page-shell page-stack page-pad-top content-band">
    <div class="prose about-copy reading-column">
      <Fragment set:html={beforeSignupHtml} />
      <NewsletterSignup />
      <Fragment set:html={afterSignupHtml} />
    </div>
    <GitHubActivity />
  </section>
</BaseLayout>
