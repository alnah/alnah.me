---
import { SITE } from "../config/site";
import { getGitHubActivity } from "../lib/github";
import { buildGitHubActivityView } from "../lib/github-view";

const activity = await getGitHubActivity(SITE.githubActivity);
const { monthColumns, recentItems, visibleWeeks, weekCount, weekdayLabels } = buildGitHubActivityView(activity);

const formatDayLabel = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric"
});

const formatEventDate = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric"
});
---

<section
  class="github-activity section-rule"
  style="padding-top: var(--github-activity-space, 1.5rem);"
>
  <div class="eyebrow">GitHub activity</div>
  {
    activity.hasLiveData ? (
      <>
        <div class="calendar-header">
          <div class="activity-summary">
            <strong>{activity.totalContributions?.toLocaleString("en-US")}</strong> contributions in the last year
          </div>
        </div>
        <div class="calendar-card" style={`--week-count:${weekCount};`}>
          <div class="calendar-scroll">
            <div class="calendar-grid">
              <div class="calendar-months">
                <div class="month-label-track">
                  {monthColumns.map((month) => (
                    <span style={`grid-column:${month.start} / span ${month.span};`}>{month.label}</span>
                  ))}
                </div>
              </div>
              <div class="calendar-body">
                <div class="weekday-labels" aria-hidden="true">
                  {weekdayLabels.map((item) => (
                    <span style={`grid-row:${item.row};`}>{item.label}</span>
                  ))}
                </div>
                <div class="calendar-weeks">
                  {visibleWeeks.map((week) => (
                    <div class="calendar-week">
                      {week.contributionDays.map((day) => (
                        <span
                          class={`contribution-cell level-${day.contributionLevel.toLowerCase()}`}
                          title={`${day.contributionCount} contribution${day.contributionCount === 1 ? "" : "s"} on ${formatDayLabel.format(new Date(day.date))}`}
                        ></span>
                      ))}
                    </div>
                  ))}
                </div>
              </div>
              <div class="calendar-footer" aria-hidden="true">
                <div class="calendar-legend">
                  <span>Less</span>
                  <span class="legend-scale"></span>
                  <span>More</span>
                </div>
              </div>
            </div>
          </div>
        </div>
          <div class="activity-subsection">
            <div class="eyebrow">Recent public activity</div>
            <ul class="activity-list">
            {recentItems.map((item) => (
              <li>
                <span class="event-date">{formatEventDate.format(new Date(item.date))}</span>
                {
                  item.url ? (
                    <a href={item.url} target="_blank" rel="noreferrer">{item.summary}</a>
                  ) : (
                    <span>{item.summary}</span>
                  )
                }
              </li>
            ))}
          </ul>
        </div>
      </>
    ) : (
      <>
        <p class="activity-intro">
          A lightweight snapshot of the kind of public work that usually feeds the writing here.
        </p>
        <ul class="activity-list">
          {recentItems.map((item) => (
            <li>{item.summary}</li>
          ))}
        </ul>
      </>
    )
  }
  <p>
    <a href={activity.profileUrl} target="_blank" rel="noreferrer">
      Follow the public work on GitHub
    </a>
  </p>
</section>

<style>
  .github-activity {
    --github-activity-space: var(--space-5);
    padding-top: var(--space-5);
    display: grid;
    gap: var(--space-4);
    width: 100%;
    max-width: min(100%, var(--width-band));
    margin-inline: 0;
  }

  .activity-summary {
    font-size: var(--font-size-xl);
    color: var(--color-text);
  }

  .activity-summary strong {
    font-family: var(--font-body);
    font-weight: 700;
  }

  .calendar-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .activity-intro {
    margin: 0;
    color: var(--color-text-muted);
  }

  .calendar-card {
    --calendar-gap: 0.1rem;
    --cell-size: 0.96rem;
    --weekday-width: 1.9rem;
    --body-gap: var(--space-2);
    padding: 0.9rem;
    display: grid;
    gap: var(--space-4);
    justify-items: start;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-surface) 94%, var(--color-bg)) 0%,
      color-mix(in srgb, var(--color-surface) 90%, var(--color-bg)) 100%
    );
    border: 1px solid color-mix(in srgb, var(--color-rule) 96%, transparent);
    border-radius: 0.7rem;
    overflow: hidden;
    box-shadow: inset 0 1px 0 color-mix(in srgb, white 14%, transparent);
  }

  .calendar-scroll {
    width: 100%;
    overflow-x: visible;
    overflow-y: hidden;
  }

  .calendar-months {
    width: max-content;
    padding-left: calc(var(--weekday-width) + var(--body-gap));
    font-family: var(--font-mono);
    font-size: var(--font-size-compact-2xs);
    color: var(--color-text-muted);
  }

  .month-label-track {
    display: grid;
    grid-template-columns: repeat(var(--week-count), var(--cell-size));
    gap: var(--calendar-gap);
    width: max-content;
  }

  .month-label-track > span {
    grid-row: 1;
    white-space: nowrap;
    text-align: left;
    overflow: visible;
  }

  .calendar-body {
    display: grid;
    grid-template-columns: var(--weekday-width) max-content;
    gap: var(--body-gap);
    align-items: start;
    width: max-content;
    max-width: 100%;
  }

  .calendar-grid {
    display: grid;
    gap: var(--space-4);
    width: max-content;
    max-width: 100%;
  }

  .weekday-labels {
    display: grid;
    grid-template-rows: repeat(7, var(--cell-size));
    gap: var(--calendar-gap);
    font-family: var(--font-mono);
    font-size: var(--font-size-compact-xs);
    color: var(--color-text-muted);
    justify-items: end;
    padding-right: 0.2rem;
    align-content: start;
  }

  .weekday-labels > span {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    line-height: 1;
    height: var(--cell-size);
  }

  .calendar-weeks {
    display: grid;
    grid-template-columns: repeat(var(--week-count), var(--cell-size));
    gap: var(--calendar-gap);
    width: max-content;
  }

  .calendar-week {
    display: grid;
    grid-template-rows: repeat(7, var(--cell-size));
    gap: var(--calendar-gap);
  }

  .contribution-cell {
    display: block;
    width: var(--cell-size);
    height: var(--cell-size);
    border-radius: 0.16rem;
    border: 1px solid color-mix(in srgb, var(--color-rule) 10%, transparent);
    box-shadow: none;
    filter: saturate(0.92);
  }

  .level-none {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-surface) 98%, transparent) 0%,
      color-mix(in srgb, var(--color-surface) 94%, var(--color-bg)) 100%
    );
    border-color: color-mix(in srgb, var(--color-rule) 4%, transparent);
    opacity: 0.72;
  }

  .level-first_quartile {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-accent) 22%, white 6%) 0%,
      color-mix(in srgb, var(--color-accent) 16%, var(--color-surface)) 100%
    );
  }

  .level-second_quartile {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-accent) 38%, white 8%) 0%,
      color-mix(in srgb, var(--color-accent) 30%, var(--color-surface)) 100%
    );
  }

  .level-third_quartile {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-accent) 56%, white 10%) 0%,
      color-mix(in srgb, var(--color-accent) 46%, var(--color-surface)) 100%
    );
  }

  .level-fourth_quartile {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-accent) 72%, white 12%) 0%,
      color-mix(in srgb, var(--color-accent) 60%, var(--color-accent-strong)) 100%
    );
  }

  .calendar-footer {
    display: flex;
    justify-content: flex-end;
    width: max-content;
    padding-left: calc(var(--weekday-width) + var(--body-gap));
    box-sizing: border-box;
  }

  .calendar-legend {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--font-size-compact-sm);
    color: var(--color-text-muted);
  }

  .legend-scale {
    display: inline-block;
    width: 4.5rem;
    height: 0.72rem;
    border-radius: 999px;
    border: 0;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-bg) 82%, black 18%);
    background:
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--color-bg) 94%, black 6%) 0%,
        color-mix(in srgb, var(--color-bg) 82%, var(--color-surface-strong)) 20%,
        color-mix(in srgb, var(--color-accent) 22%, white 5%) 42%,
        color-mix(in srgb, var(--color-accent) 42%, white 7%) 60%,
        color-mix(in srgb, var(--color-accent) 64%, white 8%) 80%,
        color-mix(in srgb, var(--color-accent) 86%, white 10%) 100%
      );
  }

  .activity-subsection {
    display: grid;
    gap: var(--space-3);
  }

  .activity-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--space-3);
  }

  .activity-list li {
    display: grid;
    gap: 0.25rem;
  }

  .activity-list a {
    text-decoration: none;
  }

  .event-date {
    font-family: var(--font-mono);
    font-size: var(--font-size-compact-sm);
    color: var(--color-text-muted);
  }

  @media (max-width: 720px) {
    .calendar-header {
      align-items: start;
    }

    .calendar-card {
      --weekday-width: 1.3rem;
      --cell-size: 0.58rem;
      padding: 0.75rem;
    }

    .calendar-months {
      font-size: var(--font-size-compact-2xs);
    }

    .calendar-body {
      --body-gap: var(--space-2);
    }

    .weekday-labels {
      font-size: var(--font-size-compact-3xs);
    }

    .calendar-weeks,
    .calendar-months {
      gap: 0.1rem;
    }

    .calendar-week {
      gap: 0.1rem;
    }

    .contribution-cell {
      border-radius: 0.1rem;
    }

    .calendar-scroll {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior-x: contain;
      scrollbar-width: thin;
      padding-bottom: var(--space-1);
    }
  }
</style>
