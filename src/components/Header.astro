---
import { Image } from "astro:assets";
import ContactLinks from "./ContactLinks.astro";
import SearchDialog from "./SearchDialog.astro";
import ThemeToggle from "./ThemeToggle.astro";
import profileImage from "../assets/profile.jpeg";
import { NAV_ITEMS, SITE } from "../config/site";

interface Props {
  isHomePage?: boolean;
}

const { isHomePage = false } = Astro.props;
const IntroTag = isHomePage ? "h1" : "p";
---

<header class="site-header">
  <div class="topbar">
    <div class="content-band topbar-inner section-rule">
      <a class="brand" href="/">{SITE.author.name}</a>
      <nav class="nav" aria-label="Navigation principale">
        <div class="nav-slot nav-slot-theme">
          <ThemeToggle />
        </div>
        <div class="nav-slot nav-slot-search">
          <SearchDialog />
        </div>
        {NAV_ITEMS.map((item) => (
          <div class={`nav-slot nav-slot-${item.id}`}>
            <a class="control-pill nav-link" href={item.href}>{item.label}</a>
          </div>
        ))}
      </nav>
    </div>
  </div>
  <div class="intro">
    <div class="content-band">
      <div class="intro-inner section-rule">
        <div class="intro-copy">
          <p class="eyebrow intro-kicker">{SITE.author.kicker}</p>
          <IntroTag class="intro-title">{SITE.author.intro}</IntroTag>
          <div class="intro-links">
            <ContactLinks variant="hero" />
          </div>
        </div>
        <Image
          class="profile-photo"
          src={profileImage}
          width="180"
          height="180"
          alt={SITE.author.photoAlt}
          loading="eager"
          fit="cover"
        />
      </div>
      <div
        class="intro-end-rule section-rule"
        aria-hidden="true"
        style="margin-top: var(--intro-end-rule-space, 1.5rem);"
      ></div>
    </div>
  </div>
</header>

<style>
  .site-header {
    padding-top: var(--space-4);
    --header-search-form-gap: var(--space-2);
    --header-search-results-offset: calc(100% + var(--space-5));
    --header-search-open-reserve: 0px;
    --intro-end-rule-space: var(--space-5);
  }

  .topbar {
    padding-bottom: 0;
  }

  .topbar-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: flex-start;
    padding-block: var(--space-2);
  }

  .intro {
    padding: 0 0 var(--space-5);
  }

  .brand {
    font-family: var(--font-mono);
    font-size: var(--font-size-lg);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    color: var(--color-text);
  }

  .nav {
    display: grid;
    grid-template-columns: var(--control-height) minmax(0, 1fr) minmax(0, 4.8rem) minmax(0, 4.8rem);
    gap: var(--space-2);
    align-items: stretch;
    width: 100%;
    position: relative;
  }

  .nav-slot {
    min-width: 0;
  }

  .nav-slot-theme {
    grid-column: 1;
    grid-row: 1;
  }

  .nav-slot-search {
    grid-column: 2;
    grid-row: 1;
    min-width: 0;
  }

  .nav-slot-posts {
    grid-column: 3;
    grid-row: 1;
  }

  .nav-slot-about {
    grid-column: 4;
    grid-row: 1;
  }

  .nav-slot-search :global([data-search-trigger]),
  .nav-slot-search :global([data-search-form]),
  .nav .nav-link {
    width: 100%;
    min-width: 0;
  }

  .nav .nav-link {
    padding-inline: var(--space-2);
  }

  .intro-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) clamp(5.5rem, 26vw, 7rem);
    gap: var(--space-4);
    align-items: start;
    padding-top: var(--space-4);
  }

  .profile-photo {
    width: clamp(5.5rem, 26vw, 7rem);
    height: clamp(5.5rem, 26vw, 7rem);
    border-radius: 999px;
    object-fit: cover;
    border: 1px solid var(--color-rule);
    background: var(--color-surface-strong);
    box-shadow: var(--shadow-sm);
    justify-self: end;
    align-self: start;
    margin-top: var(--space-2);
  }

  .intro-title {
    font-family: var(--font-heading);
    font-size: clamp(2.45rem, 11vw, 3.85rem);
    line-height: var(--line-height-tight);
    margin: 0 0 var(--space-3);
    max-width: none;
  }

  .intro-kicker {
    margin-bottom: var(--space-3);
  }

  .intro-links {
    margin-top: var(--space-6);
  }

  .intro-links :global(.contact-links[data-variant="hero"]) {
    margin-top: 0;
  }

  @media (max-width: 480px) {
    .site-header {
      --intro-end-rule-space: var(--space-4);
    }

    .topbar-inner {
      align-items: center;
    }

    .brand {
      display: block;
      width: 100%;
      text-align: center;
    }

    .nav {
      grid-template-columns: var(--control-height) minmax(0, 1fr) auto auto;
    }

    .nav .nav-link,
    .nav-slot-search :global([data-search-trigger]),
    .nav-slot-search :global([data-search-form]) {
      font-size: var(--font-size-compact-sm);
    }

    .nav .nav-link {
      white-space: nowrap;
    }

    .intro-inner {
      grid-template-columns: 1fr;
      justify-items: center;
      gap: var(--space-4);
      padding-top: var(--space-5);
      text-align: center;
    }

    .intro-copy {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      max-width: 100%;
    }

    .profile-photo {
      justify-self: center;
      align-self: center;
      width: clamp(5.5rem, 22vw, 6.25rem);
      height: clamp(5.5rem, 22vw, 6.25rem);
      margin-top: 0;
      order: -1;
    }

    .intro-title {
      order: 1;
      max-width: none;
      margin: 0;
      font-size: clamp(2.75rem, 12vw, 3.55rem);
      text-wrap: balance;
    }

    .intro-kicker {
      order: 2;
      width: min(100%, 32ch);
      margin: var(--space-2) 0 0;
    }

    .intro-links {
      order: 3;
      width: 100%;
      margin-top: var(--space-4);
    }

    .intro-links :global(.contact-links[data-variant="hero"]) {
      display: grid;
      justify-items: center;
      row-gap: var(--space-2);
      width: 100%;
    }

    .intro-links :global(.contact-links[data-variant="hero"] .social-links-list) {
      justify-content: center;
      flex-wrap: wrap;
      row-gap: var(--space-2);
      max-width: 100%;
    }
  }

  @media (max-width: 360px) {
    .nav .nav-link,
    .nav-slot-search :global([data-search-trigger]),
    .nav-slot-search :global([data-search-form]) {
      font-size: var(--font-size-compact-xs);
    }

    .intro-inner {
      gap: var(--space-3);
    }

    .intro-copy {
      max-width: 100%;
    }

    .profile-photo {
      width: 5rem;
      height: 5rem;
    }

    .intro-title {
      font-size: clamp(2.8rem, 16vw, 3.35rem);
    }

    .intro-kicker {
      width: min(100%, 26ch);
    }
  }

  @media (min-width: 901px) {
    .topbar-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      box-sizing: border-box;
      height: calc(var(--control-height) + (var(--space-3) * 2));
      padding-block: var(--space-3);
    }

    .nav {
      display: flex;
      gap: var(--space-2);
      align-items: center;
      width: auto;
      min-height: var(--control-height);
      position: static;
    }

    .nav-slot {
      min-width: initial;
    }

    .nav-slot-search :global([data-search-trigger]),
    .nav-slot-search :global([data-search-form]),
    .nav .nav-link {
      width: auto;
    }

    .nav-slot-search {
      min-height: var(--control-height);
      display: inline-flex;
      align-items: center;
    }

    .nav-slot-theme,
    .nav-slot-search,
    .nav-slot-posts,
    .nav-slot-about {
      grid-column: auto;
      grid-row: auto;
    }

    .nav .nav-link {
      padding-inline: var(--space-3);
    }

    .intro {
      padding: 0 0 var(--space-6);
    }

    .intro-inner {
      grid-template-columns: minmax(0, 42rem) 164px;
      justify-content: space-between;
      gap: var(--space-6);
      padding-top: var(--space-5);
      align-items: center;
    }

    .profile-photo {
      width: 164px;
      height: 164px;
      justify-self: start;
      align-self: center;
      margin-top: 0;
    }

    .intro-title {
      max-width: 12ch;
      font-size: clamp(3.2rem, 7vw, 4.8rem);
    }

  }

  @media (max-width: 900px) {
    .topbar-inner:has([data-search-root][data-open="true"]) {
      padding-bottom: var(--header-search-open-reserve);
    }

    .site-header {
      --header-search-results-offset: calc(100% + var(--control-height) + var(--space-4));
      --header-search-open-reserve: calc(var(--control-height) + var(--space-4));
    }
  }
</style>
